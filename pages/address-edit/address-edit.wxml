<view class="edit-page">
  <view class="form-card card">

    <view class="form-row">
      <text class="field-label">收货人</text>
      <input
        class="field-input"
        placeholder="请填写收货人姓名"
        placeholder-class="field-placeholder"
        value="{{form.receiver_name}}"
        bindinput="onFieldInput"
        data-key="receiver_name"
      />
    </view>
    <view class="field-divider"></view>

    <view class="form-row">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请填写手机号"
        placeholder-class="field-placeholder"
        value="{{form.phone}}"
        bindinput="onFieldInput"
        data-key="phone"
      />
    </view>
    <view class="field-divider"></view>

    <picker mode="region" value="{{[form.province_name, form.city_name, form.district_name]}}" bindchange="onRegionChange">
      <view class="form-row picker-row">
        <text class="field-label">所在地区</text>
        <text class="field-value {{regionDisplay ? '' : 'field-placeholder'}}">{{regionDisplay || '请选择省市区'}}</text>
        <text class="arrow-right">›</text>
      </view>
    </picker>
    <view class="field-divider"></view>

    <view class="form-row form-row--column">
      <text class="field-label">详细地址</text>
      <textarea
        class="field-textarea"
        placeholder="请填写街道、门牌号等详细信息"
        placeholder-class="field-placeholder"
        value="{{form.detail}}"
        bindinput="onFieldInput"
        data-key="detail"
        maxlength="200"
        auto-height
      />
    </view>
    <view class="field-divider"></view>

    <view class="form-row form-row--switch">
      <text class="field-label">设为默认</text>
      <switch
        color="#c9a063"
        checked="{{form.is_default}}"
        bindchange="onDefaultChange"
      />
    </view>
  </view>

  <view class="submit-wrap">
    <button
      class="btn btn-primary btn-full {{submitting ? 'btn-disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >{{submitting ? '保存中…' : '保存'}}</button>
    <view class="safe-bottom"></view>
  </view>
</view>
