<view class="log-page">
  <view class="log-list card">
    <view class="list-title">贡献值明细</view>
    <view class="divider"></view>
    <view class="list-item" wx:for="{{list}}" wx:key="id">
      <view class="log-left">
        <text class="log-remark">{{item.remark || '贡献值变动'}}</text>
        <text>{{item.type_text}}</text>
        <text class="log-time">{{item.created_at}}</text>
      </view>
      <text class="log-amount log-amount--positive">+{{item.change_amount}}</text>
    </view>

    <empty wx:if="{{!loading && list.length === 0}}" text="暂无贡献值记录" />

    <view class="load-more" wx:if="{{loading}}">加载中…</view>
    <view class="load-more" wx:if="{{!loading && noMore && list.length > 0}}">没有更多了</view>
  </view>
</view>
