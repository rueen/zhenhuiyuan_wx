<view class="log-page">
  <view class="log-list">
    <view class="log-item card" wx:for="{{list}}" wx:key="id">
      <view class="log-left">
        <text class="log-remark">{{item.remark || '贡献值变动'}}</text>
        <text class="log-time">{{item.created_at}}</text>
      </view>
      <text class="log-amount log-amount--positive">+{{item.amount}}</text>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <text class="empty-icon">📊</text>
      <text>暂无贡献值记录</text>
    </view>
    <view class="load-more" wx:if="{{loading}}">加载中…</view>
    <view class="load-more" wx:if="{{!loading && noMore && list.length > 0}}">没有更多了</view>
  </view>
</view>
