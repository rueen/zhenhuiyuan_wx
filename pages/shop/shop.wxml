<view class="shop-page">

  <!-- 搜索栏 -->
  <view class="search-bar-wrap">
    <view class="search-bar">
      <view class="search-icon"></view>
      <input
        class="search-input"
        placeholder="搜索商品"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="shop-body">

    <!-- 分类侧边栏 -->
    <scroll-view class="category-sidebar" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{activeCategoryId === item.id ? 'category-item--active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >
        <text class="category-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 商品区域 -->
    <scroll-view
      class="product-scroll"
      scroll-y
      bindscrolltolower="onReachBottom"
      lower-threshold="100"
    >
      <!-- 分类标题 -->
      <view class="category-title" wx:if="{{activeCategoryName}}">
        <text class="category-title-text">{{activeCategoryName}}</text>
      </view>

      <!-- 2 列商品网格 -->
      <view class="product-grid">
        <view
          wx:for="{{products}}"
          wx:key="id"
          class="product-card"
          bindtap="onProductTap"
          data-id="{{item.id}}"
        >
          <image class="product-img" src="{{item.cover}}" mode="aspectFill" lazy-load />
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <view class="product-footer">
              <text class="product-price"><text class="price-symbol">¥</text>{{item.price}}</text>
              <view class="add-btn" catchtap="onAddBtnTap" data-id="{{item.id}}">
                <icon name="add" size="{{20}}" />
              </view>
            </view>
          </view>
        </view>
      </view>

      <empty wx:if="{{!loading && products.length === 0}}" text="暂无商品" />

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{loading}}">加载中…</view>
      <view class="load-more" wx:if="{{!loading && noMore && products.length > 0}}">没有更多了</view>
    </scroll-view>

  </view>
</view>

<!-- 数量选择弹窗 -->
<qty-popup
  show="{{showPopup}}"
  offset-bottom="50px"
  product="{{popupProduct}}"
  action="cart"
  bindconfirm="onPopupConfirm"
  bindclose="onClosePopup"
/>
