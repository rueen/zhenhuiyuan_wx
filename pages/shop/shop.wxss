.shop-page {
  display: flex;
  flex-direction: column;
  background: #fff;
  height: 100vh;
}

/* ── 搜索栏 ── */
.search-bar-wrap {
  padding: var(--space-sm) var(--space-md);
  background: #fff;
  flex-shrink: 0;
}
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: var(--radius-xl);
  padding: 12rpx var(--space-md);
  gap: 12rpx;
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.search-input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--color-text);
  height: 48rpx;
}
.search-placeholder {
  color: var(--color-text-hint);
}

/* ── 主体：flex:1 自动撑满搜索栏以下的剩余空间，无需 JS 计算 ── */
.shop-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  overflow: hidden;
  min-height: 0;
}

/* ── 分类侧边栏 ── */
.category-sidebar {
  width: 148rpx;
  flex-shrink: 0;
  background: #f7f7f7;
}
.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  padding: var(--space-sm) 12rpx;
  text-align: center;
}
.category-item--active {
  background: #fff;
}
.category-name {
  font-size: var(--font-sm);
  color: #555;
  line-height: 1.5;
}
.category-item--active .category-name {
  color: var(--color-primary);
  font-weight: 700;
}

/* ── 商品区域 ── */
.product-scroll {
  flex: 1;
  background: #fff;
}

/* ── 分类标题 ── */
.category-title {
  padding: var(--space-md) var(--space-md) 12rpx;
}
.category-title-text {
  font-size: var(--font-l);
  font-weight: 500;
  color: var(--color-text);
}

/* ── 2 列商品网格 ── */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 0 var(--space-lg) var(--space-lg);
  gap: var(--space-lg);
}
.product-card {
  width: 240rpx;
  background: #fff;
  overflow: hidden;
}

/* 图片容器：padding-top: 100% 实现稳定的 1:1 正方形 */
.product-img-wrap {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f0f0f0;
}
.product-img {
  width: 240rpx;
  height: 240rpx;
}

/* 商品信息区 */
.product-info {
  padding: 12rpx 4rpx 4rpx;
}
.product-name {
  font-size: var(--font-sm);
  color: var(--color-text);
  font-weight: 400;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  min-height: 68rpx;
}
.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
/* 价格：黑色粗体 */
.product-price {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text);
}
/* "+" 按钮：主题色 */
.add-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 300;
  color: var(--color-primary);
  line-height: 1;
}

/* ── 悬浮购物袋入口 ── */
.cart-fab {
  position: fixed;
  right: var(--space-md);
  bottom: calc(env(safe-area-inset-bottom) + 130rpx);
  z-index: 50;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-fab-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 100rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: var(--font-xs);
  line-height: 32rpx;
  text-align: center;
  border: 2rpx solid #fff;
}

