.health-page {
  min-height: 100vh;
  background: var(--color-bg);
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-text {
  color: var(--color-text-hint);
  font-size: var(--font-sm);
}

.disabled-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: var(--space-sm);
}
.disabled-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-top: var(--space-sm);
}
.disabled-desc {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}
.contact-btn {
  margin-top: var(--space-lg);
  width: 400rpx;
}

.records-scroll {
  box-sizing: border-box;
}
.records-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-md);
}
.record-item {
  display: flex;
  align-items: center;
  padding: var(--space-md);
}
.record-main {
  flex: 1;
}
.record-name-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: 8rpx;
}
.record-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text);
}
.record-tag {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  background: var(--color-primary-light);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
}
.record-phone{
  font-size: var(--font-base);
  color: var(--color-text);
}
.record-meta-row {
  display: flex;
  gap: var(--space-sm);
}
.record-meta {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

.report-btn {
  flex-shrink: 0;
  margin-left: var(--space-sm);
}
