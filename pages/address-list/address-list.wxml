<view class="addr-list-page">
  <view class="addr-list">
    <view
      class="addr-card card"
      wx:for="{{addresses}}"
      wx:key="id"
      bindtap="onSelect"
      data-id="{{item.id}}"
    >
      <view class="addr-main">
        <view class="addr-top">
          <text class="addr-name">{{item.receiver_name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <view class="default-badge" wx:if="{{item.is_default}}">默认</view>
        </view>
        <text class="addr-detail">{{item.province_name}}{{item.city_name}}{{item.district_name}} {{item.detail}}</text>
      </view>
      <view class="addr-actions">
        <view class="action-btn" bindtap="onSetDefault" data-id="{{item.id}}" wx:if="{{!item.is_default}}">
          设为默认
        </view>
        <view class="action-btn" bindtap="onEdit" data-id="{{item.id}}">编辑</view>
        <view class="action-btn action-btn--danger" bindtap="onDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && addresses.length === 0}}">
      <text class="empty-icon">📍</text>
      <text>暂无收货地址</text>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-bar">
    <button class="btn btn-primary btn-full" bindtap="onAdd">+ 新增收货地址</button>
    <view class="safe-bottom"></view>
  </view>
</view>
