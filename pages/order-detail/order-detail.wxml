<view class="detail-page" wx:if="{{order}}">
  <scroll-view class="detail-scroll" scroll-y>

    <!-- 状态横幅 -->
    <view class="status-banner status-banner-{{order.status}}">
      <text class="status-text">{{order.statusText}}</text>
      <text class="status-sub">
        <block wx:if="{{order.status === 0}}">请尽快完成支付</block>
        <block wx:elif="{{order.status === 2}}">商品已发货，请注意查收</block>
      </text>
    </view>

    <!-- 收货地址 -->
    <view class="section card addr-card">
      <view class="addr-row">
        <view class="addr-meta">
          <text class="addr-name">{{order.receiver_snapshot.receiver_name}}</text>
          <text class="addr-phone">{{order.receiver_snapshot.phone}}</text>
        </view>
        <text class="addr-detail">{{order.receiver_snapshot.province_name}}{{order.receiver_snapshot.city_name}}{{order.receiver_snapshot.district_name}} {{order.receiver_snapshot.detail}}</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="section card items-card">
      <view class="order-item" wx:for="{{order.items}}" wx:key="id">
        <image class="item-cover" src="{{item.product_cover}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-name">{{item.product_name}}</text>
          <view class="item-bottom">
            <text class="item-price price"><text class="price-symbol">¥</text>{{item.price}}</text>
            <text class="item-qty">×{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 金额 -->
    <view class="section card fee-card">
      <view class="fee-row">
        <text class="fee-label">商品金额</text>
        <text class="fee-value">¥{{order.product_amount}}</text>
      </view>
      <view class="fee-row">
        <text class="fee-label">运费</text>
        <text class="fee-value">¥{{order.shipping_fee}}</text>
      </view>
      <view class="divider"></view>
      <view class="fee-row">
        <text class="fee-label fee-total-label">实付金额</text>
        <text class="fee-total price"><text class="price-symbol">¥</text>{{order.pay_amount}}</text>
      </view>
    </view>

    <!-- 物流信息 -->
    <view class="section card logistics-card" wx:if="{{order.shipments && order.shipments.length > 0}}">
      <view class="card-title">物流信息</view>
      <view class="shipment" wx:for="{{order.shipments}}" wx:key="id">
        <text class="ship-company">{{item.logistics_company}}</text>
        <text class="ship-no">{{item.tracking_no}}</text>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="section card order-info-card">
      <view class="info-row">
        <text class="info-label">订单号</text>
        <view class="info-value-row">
          <text class="info-value">{{order.order_no}}</text>
          <view class="copy-btn" bindtap="onCopyNo">复制</view>
        </view>
      </view>
      <view class="info-row">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.created_at}}</text>
      </view>
      <view class="info-row" wx:if="{{order.paid_at}}">
        <text class="info-label">支付时间</text>
        <text class="info-value">{{order.paid_at}}</text>
      </view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 底部操作 -->
  <view class="action-bar" wx:if="{{order.status === 0 || order.status === 1 || order.status === 2}}">
    <view class="action-bar-inner">
      <button class="btn btn-plain btn-sm" wx:if="{{order.status === 0 || order.status === 1}}" bindtap="onCancel">取消订单</button>
      <button class="btn btn-primary" wx:if="{{order.status === 0}}" bindtap="onPay">立即支付</button>
      <button class="btn btn-primary" wx:if="{{order.status === 2}}" bindtap="onConfirm">确认收货</button>
    </view>
    <view class="safe-bottom"></view>
  </view>
</view>
