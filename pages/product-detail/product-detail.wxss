/* ─────────────────────────────────────────
   分层说明：
   z-index 1  → 轮播图（固定背景）
   z-index 2  → 白色内容卡（随页面滚动上移，盖住轮播图）
   z-index 10 → 底部购买栏（固定）
   z-index 20 → 自定义导航按钮（固定，始终在最顶层）
   z-index 900/1000 → 弹窗遮罩 / 弹窗
   ───────────────────────────────────────── */

/* ── 加载中 ── */
.loading-wrap {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-text {
  color: var(--color-text-hint);
  font-size: var(--font-base);
}

/* ── 轮播图：固定在屏幕顶部，层级最低 ── */
.swiper-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 720rpx;
  z-index: 1;
}
.img-swiper {
  width: 100%;
  height: 100%;
}
.swiper-img {
  width: 100%;
  height: 100%;
}
/* 右下角计数徽章 */
.img-counter {
  position: absolute;
  right: var(--space-md);
  bottom: 64rpx;
  background: rgba(0, 0, 0, 0.38);
  color: #fff;
  font-size: var(--font-xs);
  padding: 4rpx 20rpx;
  border-radius: 100rpx;
}

/* ── 自定义导航按钮（通用）：位置由 JS 内联 style 控制 ── */
/* 圆形按钮（返回、分享） */
.nav-btn--circle {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 1;
  font-weight: normal;
}
.nav-btn--circle::after { border: none; }

/* ── 页面内容区：padding-top 为轮播图留空，白卡向上滚动覆盖轮播图 ── */
.detail-page {
  padding-top: 680rpx; /* 轮播图 720rpx - 圆角叠加 40rpx */
}

/* 白色内容卡：z-index 高于轮播图，向上滚动时遮盖图片 */
.content-card {
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: var(--space-md) var(--space-md) 0;
  min-height: 60vh;
}

/* ── 商品信息 ── */
.product-info {
  padding-bottom: var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: var(--space-md);
}
.product-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: var(--space-sm);
  display: block;
}
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-xs);
}
.product-price {
  font-size: var(--font-xxl);
  font-weight: 700;
}
.sales-badge {
  padding: 6rpx 18rpx;
  background: var(--color-primary-light);
  border-radius: 100rpx;
  font-size: var(--font-xs);
  color: var(--color-primary);
}
.product-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.meta-item {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}
.meta-divider {
  color: var(--color-border);
}

/* ── 图文详情 ── */
.detail-section {
  margin-top: var(--space-sm);
}
.section-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-md);
  display: block;
}
.detail-img {
  width: 100%;
  display: block;
}

/* 底部内容占位，避免内容被固定购买栏遮挡 */
.content-bottom-gap {
  height: 180rpx;
}

/* ── 底部购买栏：固定底部 ── */
.buy-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: #fff;
  border-top: 1rpx solid var(--color-border);
}
.buy-bar-inner {
  display: flex;
  align-items: center;
  padding: var(--space-xs) var(--space-md);
  gap: var(--space-sm);
}

/* 左侧图标组 */
.buy-icon-group {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.buy-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 80rpx;
}
.buy-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}
.buy-cart-badge {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
  border-radius: 100rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: var(--font-xs);
  line-height: 30rpx;
  text-align: center;
  border: 2rpx solid #fff;
}
.buy-icon-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  line-height: 1;
}
/* 图标区与按钮区之间的竖分隔线 */
.buy-icon-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
  margin: 0 8rpx;
}

/* 右侧操作按钮组 */
.buy-actions {
  flex: 1;
  display: flex;
  gap: var(--space-sm);
}
.buy-action-btn {
  flex: 1;
  height: 80rpx;
  font-size: var(--font-sm);
  border-radius: var(--radius-xl);
}

