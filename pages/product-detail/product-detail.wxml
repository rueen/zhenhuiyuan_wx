<!-- 加载中 -->
<view class="loading-wrap" wx:if="{{loading}}">
  <text class="loading-text">加载中…</text>
</view>

<block wx:elif="{{product}}">

  <!-- ① 轮播图（固定在顶层背景，z-index 最低） -->
  <view class="swiper-wrap">
    <swiper
      class="img-swiper"
      circular
      autoplay
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{product.main_images}}" wx:key="*this">
        <image
          class="swiper-img"
          src="{{item}}"
          mode="aspectFill"
          bindtap="onPreviewImg"
          data-src="{{item}}"
        />
      </swiper-item>
    </swiper>
    <!-- 右下角计数 -->
    <view class="img-counter" wx:if="{{product.main_images && product.main_images.length > 1}}">
      {{currentImg + 1}}/{{product.main_images.length}}
    </view>
  </view>

  <!-- ② 自定义顶部导航（z-index 最高，始终悬浮）
       位置通过 JS 计算：与系统胶囊按钮垂直对齐，分享按钮紧靠胶囊左侧 -->
  <!-- 返回按钮（左侧） -->
  <view
    class="nav-btn nav-btn--circle"
    style="position:fixed;left:{{navBackLeft}}px;top:{{navBtnTop}}px;width:{{navBtnSize}}px;height:{{navBtnSize}}px;z-index:20;"
    bindtap="onBack"
  >
    <icon name="arrow-l" size="{{16}}" color="#000" />
  </view>
  <!-- 分享按钮（系统胶囊左侧，避免重叠） -->
  <button
    class="nav-btn nav-btn--circle"
    style="position:fixed;right:{{navShareRight}}px;top:{{navBtnTop}}px;width:{{navBtnSize}}px;height:{{navBtnSize}}px;z-index:20;"
    open-type="share"
  >
    <icon name="share" size="{{16}}" color="#000" />
  </button>

  <!-- ③ 主内容区（页面级滚动，白卡向上滑动覆盖轮播图） -->
  <view class="detail-page">
    <view class="content-card">

      <!-- 商品名称 & 价格 -->
      <view class="product-info">
        <text class="product-name">{{product.name}}</text>
        <view class="price-row">
          <text class="product-price price"><text class="price-symbol">¥</text>{{product.price}}</text>
          <view class="sales-badge" wx:if="{{product.sales}}">{{product.sales}}人购</view>
        </view>
        <view class="product-no-row" wx:if="{{product.product_no}}">
          <text class="product-no-label">商品编号</text>
          <view class="product-no-value-row">
            <text class="product-no-value">{{product.product_no}}</text>
            <view class="copy-btn" bindtap="onCopyProductNo">复制</view>
          </view>
        </view>
        <view class="product-meta" wx:if="{{product.stock !== undefined || product.category_name}}">
          <text class="meta-item" wx:if="{{product.stock !== undefined}}">库存 {{product.stock}} 件</text>
          <text class="meta-divider" wx:if="{{product.category_name && product.stock !== undefined}}">·</text>
          <text class="meta-item" wx:if="{{product.category_name}}">{{product.category_name}}</text>
        </view>
      </view>

      <!-- 图文详情 -->
      <view class="detail-section" wx:if="{{product.detail_images && product.detail_images.length > 0}}">
        <view class="section-title">商品详情</view>
        <image
          class="detail-img"
          wx:for="{{product.detail_images}}"
          wx:key="*this"
          src="{{item}}"
          mode="widthFix"
          lazy-load
        />
      </view>

      <!-- 底部安全占位（为固定购买栏留空） -->
      <view class="content-bottom-gap"></view>
    </view>
  </view>

  <!-- ④ 底部购买栏（固定底部） -->
  <view class="buy-bar">
    <view class="buy-bar-inner">
      <!-- 左侧图标区 -->
      <view class="buy-icon-group">
        <view class="buy-icon-item" bindtap="onServiceTap">
          <view class="buy-icon">
            <icon name="service" size="{{24}}" />
          </view>
          <text class="buy-icon-label">客服</text>
        </view>
        <view class="buy-icon-divider"></view>
        <view class="buy-icon-item" bindtap="onCartTap">
          <view class="buy-icon">
            <icon name="cart" size="{{26}}" />
            <view class="buy-cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
          </view>
          <text class="buy-icon-label">购物袋</text>
        </view>
      </view>
      <!-- 右侧操作按钮 -->
      <view class="buy-actions">
        <button class="btn btn-plain buy-action-btn" bindtap="onAddToCart">加入购物袋</button>
        <button class="btn btn-primary buy-action-btn" bindtap="onBuyNow">立即购买</button>
      </view>
    </view>
    <view class="safe-bottom"></view>
  </view>

  <!-- 数量选择弹窗 -->
  <qty-popup
    show="{{showPopup}}"
    product="{{product}}"
    action="{{popupAction}}"
    bindconfirm="onPopupConfirm"
    bindclose="onClosePopup"
  />

</block>
