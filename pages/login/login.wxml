<view class="login-page">
  <!-- 品牌区 -->
  <view class="brand-area">
    <view class="brand-name">贞慧缘</view>
    <view class="brand-sub">发现美好 共享生活</view>
  </view>

  <!-- 弹性占位 -->
  <view class="login-spacer"></view>

  <!-- 邀请码输入 -->
  <view class="invite-wrap">
    <input
      class="invite-input"
      placeholder="邀请码（选填）"
      placeholder-class="invite-placeholder"
      value="{{inviteCode}}"
      bindinput="onInviteInput"
    />
  </view>

  <!-- 底部操作区 -->
  <view class="login-footer">
    <!-- 用户协议勾选 -->
    <view class="agreement-wrap" bindtap="toggleAgreed">
      <view class="checkbox {{agreed ? 'checkbox--checked' : ''}}"></view>
      <text class="agreement-text">我已认真阅读并同意 </text>
      <text class="agreement-link" catchtap="onAgreementTap">《用户协议和隐私政策》</text>
    </view>

    <!-- 微信登录按钮 -->
    <button
      class="btn btn-primary btn-full wx-login-btn {{loading ? 'btn-disabled' : ''}}"
      bindtap="onWxLogin"
      disabled="{{loading}}"
    >{{loading ? '登录中…' : '微信登录'}}</button>

    <!-- 游客登录 -->
    <view class="guest-login" bindtap="onGuestLogin">
      <text class="guest-login-text">游客登录</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
