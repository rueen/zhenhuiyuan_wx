<view class="login-page">
  <!-- 顶部品牌区 -->
  <view class="brand-area">
    <view class="brand-name">贞慧缘</view>
    <view class="brand-sub">发现美好，共享生活</view>
  </view>

  <!-- 登录表单卡片 -->
  <view class="form-card card">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="form-divider"></view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input
        class="form-input"
        password
        maxlength="32"
        placeholder="请输入密码（6~32位）"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 邀请码（可折叠） -->
    <view class="form-divider"></view>
    <view class="form-invite-toggle" bindtap="toggleInvite">
      <text class="invite-toggle-text">有邀请码？点击填写</text>
      <text class="invite-arrow {{showInvite ? 'invite-arrow--open' : ''}}">›</text>
    </view>
    <view class="form-item invite-item" hidden="{{!showInvite}}">
      <text class="form-label">邀请码</text>
      <input
        class="form-input"
        placeholder="选填，注册时绑定上级"
        placeholder-class="input-placeholder"
        value="{{inviteCode}}"
        bindinput="onInviteInput"
      />
    </view>
  </view>

  <!-- 登录按钮 -->
  <button
    class="btn btn-primary btn-full login-btn {{loading ? 'btn-disabled' : ''}}"
    bindtap="onLogin"
    disabled="{{loading}}"
  >{{loading ? '登录中…' : '登录 / 注册'}}</button>

  <view class="login-hint">未注册的手机号将自动注册账号</view>
</view>
