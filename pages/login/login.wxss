.login-page {
  min-height: 100vh;
  padding: 0 var(--space-lg);
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* ── logo区 ── */
.logo-area{
  width: 100%;
  display: flex;
  justify-content: center;
  padding-top: 180rpx;
}
.logo{
  width: 230rpx;
  height: 200rpx;
}

/* ── 弹性占位 ── */
.login-spacer {
  flex: 1;
  min-height: 80rpx;
}

/* ── 邀请码输入 ── */
.invite-wrap {
  margin-bottom: var(--space-xl);
  padding: 0 var(--space-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}
.invite-input {
  width: 380rpx;
  height: 96rpx;
  background: var(--color-bg);
  border-radius: 48rpx;
  padding: 0 var(--space-lg);
  font-size: var(--font-base);
  color: var(--color-text);
  text-align: center;
}
.invite-placeholder {
  color: var(--color-text-hint);
  text-align: center;
}

/* ── 底部操作区 ── */
.login-footer {
  padding-bottom: var(--space-xl);
}

/* ── 用户协议 ── */
.agreement-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
  flex-wrap: wrap;
}
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  margin-right: var(--space-xs);
  flex-shrink: 0;
  position: relative;
}
.checkbox--checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
.checkbox--checked::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 10rpx;
  height: 18rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}
.agreement-text {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}
.agreement-link {
  font-size: var(--font-sm);
  color: var(--color-primary);
}

/* ── 微信登录按钮 ── */
.wx-login-btn {
  height: 96rpx;
  border-radius: 48rpx;
  font-size: var(--font-md);
  font-weight: 600;
  letter-spacing: 4rpx;
  margin-bottom: var(--space-lg);
}

/* ── 游客登录 ── */
.guest-login {
  text-align: center;
  padding: var(--space-sm) 0;
}
.guest-login-text {
  font-size: var(--font-base);
  color: var(--color-text-sub);
  text-decoration: underline;
}

/* ── 注册：欢迎语 ── */
.welcome-area {
  display: flex;
  flex-direction: column;
  padding-top: 60rpx;
}
.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
}
.welcome-sub {
  margin-top: var(--space-sm);
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}

/* ── 注册：头像 ── */
.reg-avatar-area {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}
.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}
.avatar-img,
.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}
.avatar-placeholder {
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-icon {
  font-size: 80rpx;
  line-height: 1;
  opacity: 0.5;
}
.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

/* ── 注册：表单 ── */
.reg-form {
  padding: 0 var(--space-xs);
}
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 110rpx;
}
.form-label {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text);
  flex-shrink: 0;
  width: 160rpx;
}
.required {
  color: var(--color-danger);
  font-size: var(--font-base);
}
.form-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
  height: 60rpx;
}
.form-placeholder {
  color: var(--color-text-hint);
}
.form-value {
  font-size: var(--font-base);
  color: var(--color-text);
}
.form-divider {
  height: 1rpx;
  background: var(--color-border);
}
button.get-phone-btn {
  font-size: var(--font-base);
  color: var(--color-primary);
  background: transparent;
  padding: 4rpx 24rpx;
  margin: 0;
  height: auto;
  line-height: 1.8;
  border: 1rpx solid var(--color-primary);
  border-radius: 100rpx;
  font-weight: normal;
}
button.get-phone-btn::after { border: none; }

