.home-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #8d570d 0%, #c07a1a 50%, #f6e3bb 100%);
}

.home-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.logo-text {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 12rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.slogan {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  letter-spacing: 6rpx;
}
