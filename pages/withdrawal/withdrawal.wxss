.withdrawal-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}

/* ── 余额卡片 ── */
.balance-card {
  background: #fff;
  padding: var(--space-lg);
}
.balance-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}
.balance-label {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}
.balance-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(-color-text);
}

.balance-sub-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: var(--space-md);
  padding: 0 var(--space-md);
}
.balance-sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.sub-label { font-size: var(--font-xs); color: var(--color-text-sub); }
.sub-value { font-size: var(--font-md); color: var(--color-text); font-weight: 500; }

/* ── 功能菜单 ── */
.menu-list-wrap {
  padding: 0 var(--space-md);
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}
.menu-item:last-child { border-bottom: none; }
.menu-item-label {
  font-size: var(--font-base);
  color: var(--color-text);
}

/* ── 遮罩 + 申请面板 ── */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}
.apply-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
  background: #fff;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: var(--space-lg) var(--space-md) var(--space-md);
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.apply-panel--show { transform: translateY(0); }

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}
.panel-title { font-size: var(--font-lg); font-weight: 600; }
.panel-close { font-size: var(--font-lg); color: var(--color-text-sub); padding: 10rpx; }

.panel-section { margin-bottom: var(--space-md); }
.panel-label {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  margin-bottom: var(--space-xs);
  display: block;
}
.account-list { display: flex; flex-direction: column; gap: var(--space-xs); }
.account-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
}
.account-item--active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}
.account-type {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  padding: 4rpx 16rpx;
  background: var(--color-bg);
  border-radius: 100rpx;
  flex-shrink: 0;
}
.account-no { font-size: var(--font-base); color: var(--color-text); }

.amount-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-xs);
}
.amount-max {
  font-size: var(--font-sm);
  color: var(--color-primary);
}
.amount-input-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  border-bottom: 2rpx solid var(--color-primary);
  padding-bottom: var(--space-xs);
  margin-bottom: var(--space-xs);
}
.amount-symbol {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
}
.amount-input {
  flex: 1;
  font-size: var(--font-xl);
  color: var(--color-text);
  font-weight: 600;
  height: 80rpx;
}
.amount-hint { font-size: var(--font-xs); color: var(--color-text-hint); }
.field-placeholder { color: var(--color-text-hint); }

.add-account-link {
  display: block;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--color-primary);
  padding: var(--space-xs) 0;
}

.panel-rules {
  margin-bottom: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}
.panel-rules-title {
  display: block;
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--color-text-sub);
  margin-bottom: var(--space-xs);
}
.panel-rules-item {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  line-height: 1.6;
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
