<view class="withdrawal-page">

  <!-- 余额卡片 -->
  <view class="balance-card">
    <view class="balance-main">
      <text class="balance-label">可提现余额</text>
      <text class="balance-value"><text class="price-symbol">¥</text>{{info ? info.withdrawable_balance : '--'}}</text>
    </view>
    <view class="balance-sub-row">
      <view class="balance-sub-item">
        <text class="sub-label">提现中</text>
        <text class="sub-value">¥{{info ? info.frozen_amount : '--'}}</text>
      </view>
      <view class="balance-sub-item">
        <text class="sub-label">可用</text>
        <text class="sub-value">¥{{info ? info.available_amount : '--'}}</text>
      </view>
    </view>
    <button class="btn btn-primary btn-full" bindtap="onApply">申请提现</button>
  </view>

  <!-- 功能入口 -->
  <view class="section">
    <view class="card">
      <view class="menu-list-wrap">
        <view class="menu-item" bindtap="onRecordsTap">
          <text class="menu-item-label">提现记录</text>
          <text class="arrow-right">›</text>
        </view>
        <view class="menu-item" bindtap="onBalanceLogsTap">
          <text class="menu-item-label">余额流水</text>
          <text class="arrow-right">›</text>
        </view>
        <view class="menu-item" bindtap="onAccountsTap">
          <text class="menu-item-label">提现账户</text>
          <text class="arrow-right">›</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 提现规则 -->
  <view class="panel-rules">
    <view class="panel-rules-title">提现规则</view>
    <view class="panel-rules-item" wx:for="{{ruleItems}}" wx:key="*this">
      <text>{{index + 1}}. {{item.label}}:</text>
      <text>{{item.value}}</text>
    </view>
    <view class="panel-rules-item">8. 提现需经平台审核，审核通过后将打款至您绑定的银行卡/支付宝/微信账户</view>
  </view>

  <!-- 申请弹窗遮罩 -->
  <view class="mask" wx:if="{{showApplyPanel}}" bindtap="onClosePanel"></view>

  <!-- 申请面板 -->
  <view class="apply-panel {{showApplyPanel ? 'apply-panel--show' : ''}}">
    <view class="panel-header">
      <text class="panel-title">申请提现</text>
      <text class="panel-close" bindtap="onClosePanel">✕</text>
    </view>

    <!-- 选择账户 -->
    <view class="panel-section">
      <text class="panel-label">提现账户</text>
      <view class="account-list">
        <view
          class="account-item {{selectedAccountId === item.id ? 'account-item--active' : ''}}"
          wx:for="{{accounts}}"
          wx:key="id"
          bindtap="onSelectAccount"
          data-id="{{item.id}}"
        >
          <text class="account-type">{{item.typeName}}</text>
          <text class="account-no">{{item.account_no_mask}}</text>
        </view>
        <block wx:if="{{accounts.length === 0}}">
          <empty text="暂无提现账户，请先添加" />
          <text class="add-account-link" bindtap="onAddAccountTap">去添加提现账户</text>
        </block>
      </view>
    </view>

    <!-- 金额输入 -->
    <view class="panel-section">
      <view class="amount-label-row">
        <text class="panel-label">提现金额</text>
        <text class="amount-max" bindtap="onFillMax">全部提现</text>
      </view>
      <view class="amount-input-wrap">
        <text class="amount-symbol">¥</text>
        <input
          class="amount-input"
          type="digit"
          placeholder="请输入金额"
          placeholder-class="field-placeholder"
          value="{{applyAmount}}"
          bindinput="onAmountInput"
        />
      </view>
      <text class="amount-hint">可用 ¥{{info ? info.available_amount : '--'}}，最低提现 ¥{{info ? info.min_amount : '--'}}</text>
    </view>

    <button
      class="btn btn-primary btn-full {{submitting ? 'btn-disabled' : ''}}"
      bindtap="onSubmitApply"
      disabled="{{submitting}}"
    >{{submitting ? '提交中…' : '确认提现'}}</button>
    <view class="safe-bottom"></view>
  </view>
</view>
