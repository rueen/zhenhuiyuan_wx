
.mine-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}

/* ── 头部卡片 ── */
.mine-header-card {
  padding: var(--space-md);
}

/* 用户信息行 */
.user-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}
.user-info-area {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
}
.user-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-border);
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-default {
  width: 100%;
  height: 100%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-letter {
  font-size: var(--font-xl);
  color: var(--color-primary);
  font-weight: 600;
}
.user-meta {
  flex: 1;
}
.user-name-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: 10rpx;
}
.user-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
}
.level-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  background: var(--color-primary);
  border-radius: 100rpx;
  font-size: var(--font-xs);
  color: #fff;
}
.level-hint {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
  display: flex;
  align-items: center;
}

/* 邀请码按钮 */
.invite-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.invite-icon-slot {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.invite-btn-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

/* 资产统计行 */
.stats-row {
  display: flex;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-sm) 0;
  gap: 8rpx;
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}
.stat-value-wrap{
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
  display: flex;
  justify-content: center;
  align-items: center;
}
.stat-value--empty {
  color: var(--color-text-hint);
  font-weight: 400;
}
.stat-divider {
  width: 1rpx;
  background: var(--color-border);
  margin: var(--space-sm) 0;
}

/* ── 订单 tabs ── */
.order-tabs {
  display: flex;
  padding: var(--space-md) var(--space-xs);
}
.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-xs) 0;
}
.order-tab-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.order-tab-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}

/* ── 菜单列表 ── */
.menu-list-wrap {
  padding: 0 var(--space-md);
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}
.menu-item:last-child { border-bottom: none; }
.menu-item-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.menu-item-label {
  font-size: var(--font-base);
  color: var(--color-text);
}

/* ── 退出登录 ── */
.logout-section { margin-top: var(--space-md); }
.logout-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-md);
}
.logout-text {
  font-size: var(--font-base);
  color: var(--color-danger);
}
