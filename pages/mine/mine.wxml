<view class="mine-page">

  <!-- 头部卡片 -->
  <view class="section">
    <view class="card mine-header-card">
      <view class="user-row">
        <!-- 头像 + 用户信息，未登录时点击跳转登录 -->
        <view class="user-info-area" bindtap="onUserAreaTap">
          <view class="user-avatar">
            <image wx:if="{{profile && profile.avatar}}" class="avatar-img" src="{{profile.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar-default">
              <text wx:if="{{profile}}" class="avatar-letter">{{profile.nickname ? profile.nickname[0] : '?'}}</text>
            </view>
          </view>
          <view class="user-meta">
            <view class="user-name-row">
              <text class="user-name">{{profile ? (profile.nickname || '未设置昵称') : '点击登录'}}</text>
              <view class="level-badge" wx:if="{{profile}}">
                <text>{{profile.level_name}}</text>
                <icon name="arrow-r" size="{{10}}" color="#fff" />
              </view>
            </view>
            <text class="level-hint" wx:if="{{profile}}">再获得{{profile.points_to_next_level || 1000}}贡献值升级为下一等级</text>
            <text class="level-hint" wx:if="{{!profile}}">登录后享受更多服务</text>
          </view>
        </view>
        <!-- 邀请码，仅登录后显示 -->
        <view class="invite-btn" wx:if="{{profile}}" bindtap="onCopyInviteCode">
          <view class="invite-icon-slot">
            <icon name="qrcode" size="{{26}}" color="#666" />
          </view>
          <text class="invite-btn-label">邀请码</text>
        </view>
      </view>
      <!-- 资产行 -->
      <view class="stats-row">
        <view class="stat-item" bindtap="onWithdrawTap">
          <text class="stat-label">余额</text>
          <view class="stat-value-wrap">
            <text class="stat-value {{!profile ? 'stat-value--empty' : ''}}">{{profile ? '¥' + profile.withdrawable_balance : '--'}}</text>
            <icon name="arrow-r" size="{{12}}" wx:if="{{profile}}" />
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onContributionTap">
          <text class="stat-label">贡献值</text>
          <view class="stat-value-wrap">
            <text class="stat-value {{!profile ? 'stat-value--empty' : ''}}">{{profile ? profile.cumulative_contribution : '--'}}</text>
            <icon name="arrow-r" size="{{12}}" wx:if="{{profile}}" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="section">
    <view class="card">
      <view class="order-tabs">
        <view
          class="order-tab"
          wx:for="{{orderTabs}}"
          wx:key="status"
          bindtap="onOrderTabTap"
          data-status="{{item.status}}"
        >
          <view class="order-tab-icon">
            <icon name="{{item.icon}}" size="{{30}}" color="#000" />
          </view>
          <text class="order-tab-label">{{item.label}}</text>
        </view>
        <view class="order-tab" bindtap="onAllOrdersTap">
          <view class="order-tab-icon">
            <icon name="order" size="{{30}}" color="#000" />
          </view>
          <text class="order-tab-label">全部订单</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="card menu-list">
      <view class="menu-list-wrap">
        <view
          class="menu-item"
          wx:for="{{menuItems}}"
          wx:key="path"
          bindtap="onMenuTap"
          data-path="{{item.path}}"
          data-auth="{{item.auth}}"
        >
          <view class="menu-item-left">
            <text class="menu-item-label">{{item.label}}</text>
          </view>
          <icon name="arrow-r" size="{{16}}" color="#999" />
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录，仅登录后显示 -->
  <view class="section logout-section" wx:if="{{profile}}">
    <view class="card">
      <view class="logout-item" bindtap="onLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
