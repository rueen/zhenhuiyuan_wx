.order-list-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* ── 状态 Tab ── */
.tab-bar-scroll {
  flex-shrink: 0;
  background: #fff;
  border-bottom: 1rpx solid var(--color-border);
  white-space: nowrap;
}
.tab-row {
  display: flex;
}
.tab-cell {
  flex: 1;
  flex-shrink: 0;
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  position: relative;
  text-align: center;
}
.tab-cell--active {
  color: var(--color-primary);
  font-weight: 600;
}
.tab-cell--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ── 订单滚动 ── */
.order-scroll {
  flex: 1;
  padding: var(--space-sm) var(--space-md);
}

/* ── 订单卡片 ── */
.order-card {
  margin-bottom: var(--space-sm);
  padding: 0;
  overflow: hidden;
}
.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-md) var(--space-sm);
}
.order-status {
  font-size: var(--font-base);
  font-weight: 600;
}

.order-items {
  padding: var(--space-xs) var(--space-md);
}
.order-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}
.item-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  flex-shrink: 0;
}
.item-info { flex: 1; }
.item-name {
  font-size: var(--font-base);
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.item-price { font-size: var(--font-base); font-weight: 600; }
.item-qty { font-size: var(--font-xs); color: var(--color-text-hint); }

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: var(--space-xs) var(--space-md) var(--space-md);
}
.order-footer-right{
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}
.order-total { font-size: var(--font-md); font-weight: 700; }

