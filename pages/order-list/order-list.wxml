<view class="order-list-page">

  <!-- 状态标签栏 -->
  <scroll-view class="tab-bar-scroll" scroll-x>
    <view class="tab-row">
      <view
        class="tab-cell {{activeTab === index ? 'tab-cell--active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="label"
        bindtap="onTabTap"
        data-index="{{index}}"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <scroll-view class="order-scroll" scroll-y bindscrolltolower="onReachBottom" lower-threshold="100">

    <view class="order-card card" wx:for="{{orders}}" wx:key="id" bindtap="onOrderTap" data-id="{{item.id}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-no">订单号：{{item.order_no}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>

      <!-- 商品列表（最多显示2个） -->
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="good">
          <image class="item-cover" src="{{good.cover}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{good.product_name || good.name}}</text>
            <view class="item-bottom">
              <text class="item-price price"><text class="price-symbol">¥</text>{{good.price}}</text>
              <text class="item-qty">×{{good.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 合计 -->
      <view class="order-footer">
        <text class="order-total-label">实付：</text>
        <text class="order-total price"><text class="price-symbol">¥</text>{{item.pay_amount}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions" catchtap="stopBubble">
        <button class="btn btn-plain btn-sm" wx:if="{{item.status === 0}}" catchtap="onCancel" data-id="{{item.id}}">取消订单</button>
        <button class="btn btn-primary btn-sm" wx:if="{{item.status === 0}}" catchtap="onPay" data-id="{{item.id}}">去支付</button>
        <button class="btn btn-plain btn-sm" wx:if="{{item.status === 1}}" catchtap="onCancel" data-id="{{item.id}}">取消订单</button>
        <button class="btn btn-primary btn-sm" wx:if="{{item.status === 2}}" catchtap="onConfirm" data-id="{{item.id}}">确认收货</button>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && orders.length === 0}}">
      <text class="empty-icon">📋</text>
      <text>暂无订单</text>
    </view>
    <view class="load-more" wx:if="{{loading}}">加载中…</view>
    <view class="load-more" wx:if="{{!loading && noMore && orders.length > 0}}">没有更多了</view>
  </scroll-view>
</view>
