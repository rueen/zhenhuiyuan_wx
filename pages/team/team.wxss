.team-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: var(--space-md);
}

.stats-card {
  display: flex;
  margin-bottom: var(--space-md);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) 0;
  gap: 8rpx;
}
.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}
.stat-divider {
  width: 1rpx;
  background: var(--color-border);
  margin: var(--space-sm) 0;
}

.depth-tabs {
  display: flex;
  margin-bottom: var(--space-md);
  overflow: hidden;
}
.depth-tab {
  flex: 1;
  text-align: center;
  padding: var(--space-sm) 0;
  font-size: var(--font-sm);
  color: var(--color-text-sub);
  border-right: 1rpx solid var(--color-border);
}
.depth-tab:last-child { border-right: none; }
.depth-tab--active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-primary-bg);
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
.member-card {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md);
}
.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg);
}
.avatar-img { width: 100%; height: 100%; }
.avatar-default {
  width: 100%;
  height: 100%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  color: var(--color-primary);
  font-weight: 600;
}
.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.member-name {
  font-size: var(--font-base);
  color: var(--color-text);
  font-weight: 500;
}
.member-level {
  font-size: var(--font-xs);
  color: var(--color-text-sub);
}
.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.member-contribution {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
}
.member-contrib-label {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
