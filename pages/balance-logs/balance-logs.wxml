<view class="log-list card">
  <view class="list-item" wx:for="{{list}}" wx:key="id">
    <view class="log-left">
      <text class="log-remark">{{item.remark || '余额变动'}}</text>
      <text class="log-time">{{item.created_at}}</text>
    </view>
    <text class="log-amount {{item.change_amount > 0 ? 'log-amount--positive' : 'log-amount--negative'}}">{{item.change_amount > 0 ? '+' : ''}}{{item.change_amount}}</text>
  </view>

  <empty wx:if="{{!loading && list.length === 0}}" text="暂无余额记录" />
  <view class="load-more" wx:if="{{loading}}">加载中…</view>
  <view class="load-more" wx:if="{{!loading && noMore && list.length > 0}}">没有更多了</view>
</view>
