<view class="checkout-page" wx:if="{{product}}">
  <scroll-view class="checkout-scroll" scroll-y>

    <!-- 收货地址 -->
    <view class="section card addr-card" bindtap="onChooseAddress">
      <view wx:if="{{selectedAddress}}" class="addr-selected">
        <view class="addr-main">
          <text class="addr-name">{{selectedAddress.receiver_name}}</text>
          <text class="addr-phone">{{selectedAddress.phone}}</text>
        </view>
        <view class="addr-detail">{{selectedAddress.province_name}}{{selectedAddress.city_name}}{{selectedAddress.district_name}} {{selectedAddress.detail}}</view>
      </view>
      <view wx:else class="addr-empty">
        <text>请选择收货地址</text>
      </view>
      <text class="arrow-right">›</text>
    </view>

    <!-- 商品信息 -->
    <view class="section card goods-card">
      <image class="goods-cover" src="{{product.cover}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{product.name}}</text>
        <view class="goods-bottom">
          <text class="goods-price price"><text class="price-symbol">¥</text>{{product.price}}</text>
          <text class="goods-qty">×{{quantity}}</text>
        </view>
      </view>
    </view>

    <!-- 金额明细 -->
    <view class="section card fee-card">
      <view class="fee-row">
        <text class="fee-label">商品金额</text>
        <text class="fee-value">¥{{preview ? preview.product_amount : '--'}}</text>
      </view>
      <view class="fee-row">
        <text class="fee-label">运费</text>
        <text class="fee-value">{{preview ? ('¥' + preview.shipping_fee) : '—'}}</text>
      </view>
      <view class="fee-divider"></view>
      <view class="fee-row fee-total-row">
        <text class="fee-label fee-total-label">实付金额</text>
        <text class="fee-total price"><text class="price-symbol">¥</text>{{preview ? preview.pay_amount : '—'}}</text>
      </view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 底部提交 -->
  <view class="submit-bar">
    <view class="submit-bar-inner">
      <view class="submit-total">
        <text class="total-label">合计：</text>
        <text class="total-price price"><text class="price-symbol">¥</text>{{preview ? preview.pay_amount : '—'}}</text>
      </view>
      <button
        class="btn btn-primary submit-btn {{submitting ? 'btn-disabled' : ''}}"
        bindtap="onSubmit"
        disabled="{{submitting}}"
      >{{submitting ? '提交中…' : '提交订单'}}</button>
    </view>
    <view class="safe-bottom"></view>
  </view>
</view>
