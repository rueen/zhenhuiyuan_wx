/**
 * pages/agreement/agreement.wxss
 * 用户协议和隐私政策页面样式
 */

.agreement-page {
  background-color: #f8f9fa;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 标签切换 */
.tab-container {
  display: flex;
  background-color: #ffffff;
  margin: 32rpx 32rpx 24rpx;
  border-radius: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.tab-active {
  background-color: #333;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #666666;
}

.tab-item.tab-active .tab-text {
  color: #ffffff;
}

/* 内容容器 */
.content-container {
  margin: 0 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
}

/* 状态区（加载中 / 失败 / 空） */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e0e0;
  border-top-color: #333;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: 28rpx;
  color: #999999;
}

.state-error {
  color: #e55;
}

.retry-btn {
  margin-top: 8rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  background-color: #333;
  color: #ffffff;
  font-size: 28rpx;
}

/* 富文本内容 */
.rich-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333333;
  word-break: break-all;
}
