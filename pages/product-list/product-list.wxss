/**
 * pages/product-list/product-list.wxss
 * 商品列表页样式
 */

.product-list-page {
  background-color: var(--color-bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 2 列商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--space-md);
  gap: var(--space-md);
}

.product-card {
  width: calc(50% - 20rpx);
  background: var(--color-card);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 340rpx;
  display: block;
}

.product-info {
  padding: 12rpx 16rpx 16rpx;
}

.product-name {
  font-size: var(--font-sm);
  color: var(--color-text);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  min-height: 68rpx;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text);
}

.price-symbol {
  font-size: var(--font-sm);
}

.add-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
}

/* 状态区 */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e0e0;
  border-top-color: #333;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}

.state-error {
  color: var(--color-danger);
}

.retry-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-xl);
  background-color: var(--color-text);
  color: #fff;
  font-size: var(--font-sm);
}
