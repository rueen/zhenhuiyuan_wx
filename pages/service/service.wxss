.service-page {
  min-height: 100vh;
  background: var(--color-bg);
}

.service-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx var(--space-md) 48rpx;
  gap: var(--space-sm);
}

.service-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
}

.service-desc {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}

.service-list {
  padding: 0 var(--space-md);
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
}

.service-item + .service-item {
  border-top: 1rpx solid var(--color-border);
}

.service-item--hover {
  opacity: 0.7;
}

.service-item-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  min-width: 0;
}

.service-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.service-item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.service-item-label {
  font-size: var(--font-base);
  color: var(--color-text);
}

.service-item-value {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-primary);
}

.service-item-desc {
  font-size: var(--font-sm);
  color: var(--color-text-sub);
}

.service-contact-btn {
  width: 100%;
  margin: 0;
  padding: var(--space-md) 0;
  background: transparent;
  border: none;
  border-radius: 0;
  font-weight: normal;
  line-height: inherit;
  text-align: left;
}

.service-contact-btn::after {
  border: none;
}
