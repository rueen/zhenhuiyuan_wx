/* ── Tab Bar 容器 ── */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  display: flex;
  align-items: stretch;
  background: #fff;
  border-top: 1rpx solid #ebebeb;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 10rpx;
  gap: 6rpx;
  transition: color 0.2s;
}

/* ── 文字 ── */
.tab-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1;
}
.tab-item--active .tab-text {
  color: #c9a063;
}

/* ── 图标 ── */
.tab-icon {
  width: 52rpx;
  height: 52rpx;
}
