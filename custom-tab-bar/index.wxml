<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
    bindtap="switchTab"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
  >
    <view class="icon-wrap">
      <icon name="{{item.icon}}" size="{{30}}" color="#000" />
      <view class="icon-bg"></view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
